<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.tahtalı.hatirlatik.presentation.home.HomeFragment"
        android:label="@string/nav_home">
        <action
            android:id="@+id/action_home_to_add_task"
            app:destination="@id/dialog_add_task" />
    </fragment>

    <fragment
        android:id="@+id/navigation_calendar"
        android:name="com.tahtalı.hatirlatik.presentation.calendar.CalendarFragment"
        android:label="@string/nav_calendar" />

    <fragment
        android:id="@+id/navigation_settings"
        android:name="com.tahtalı.hatirlatik.presentation.settings.SettingsFragment"
        android:label="@string/nav_settings" />

    <dialog
        android:id="@+id/dialog_add_task"
        android:name="com.tahtalı.hatirlatik.presentation.task.AddTaskDialog"
        android:label="@string/add_task" />

</navigation> 